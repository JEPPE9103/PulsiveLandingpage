# Public site URL (canonical / OG / sitemap)
NEXT_PUBLIC_SITE_URL=https://www.pulzive.com

# Optional override for FormSubmit inbox (defaults to hello@pulzive.com)
NEXT_PUBLIC_WAITLIST_EMAIL=hello@pulzive.com

# Optional: CRM webhook (Airtable / Make / Zapier / Sheets)
WAITLIST_WEBHOOK_URL=

# Optional: Resend (email alerts + audience contacts)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
WAITLIST_NOTIFY_EMAIL=hello@pulzive.com
RESEND_FROM=PULZIVE <hello@pulzive.com>

# Notes:
# - Primary store: FormSubmit from the browser → hello@pulzive.com (no API key)
# - First live signup sends FormSubmit's Activate email — click Activate once
# - Webhook / Resend are optional server-side upgrades
