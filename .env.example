# Public site URL (canonical / OG / sitemap)
NEXT_PUBLIC_SITE_URL=https://pulzive.com

# Optional: CRM webhook (Airtable / Make / Zapier / Sheets)
WAITLIST_WEBHOOK_URL=

# Optional: Resend (email alerts + audience contacts)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
WAITLIST_NOTIFY_EMAIL=hello@pulzive.com
RESEND_FROM=PULZIVE <hello@pulzive.com>

# Notes:
# - Production waitlist works OUT OF THE BOX via FormSubmit → hello@pulzive.com
# - First live signup sends an activation email from FormSubmit — click Activate once
# - Webhook / Resend are optional upgrades for CRM + richer alerts
